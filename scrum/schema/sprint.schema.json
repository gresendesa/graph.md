{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "id",
    "schema",
    "record_type",
    "status",
    "owner",
    "created",
    "last_updated",
    "focus",
    "po_priority",
    "sprint_risk"
  ],
  "properties": {
    "id": { "type": "string", "pattern": "^SPR-[0-9]{4}-[0-9]{2}$" },
    "schema": { "type": "string" },
    "record_type": { "const": "sprint" },
    "status": { "enum": ["todo", "doing", "blocked", "done", "obsolete"] },
    "owner": { "type": "string" },
    "created": { "type": "string" },
    "last_updated": { "type": "string" },
    "focus": { "type": "string" },
    "po_priority": {
      "type": "array",
      "items": { "type": "string" }
    },
    "sprint_risk": { "enum": ["low", "medium", "high"] },
    "selected_items": {
      "type": "array",
      "items": { "type": "string" }
    },
    "version": { "type": "string" }
  },
  "additionalProperties": true
}
